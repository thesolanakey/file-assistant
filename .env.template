ANTHROPIC_API_KEY=your_claude_api_key_here
GENERATION_BACKEND=claude
CLAUDE_MODEL=claude-sonnet-4-6
# Ollama backend (used when GENERATION_BACKEND=ollama; falls back to Claude if
# unreachable). host.docker.internal points at the Docker host; ensure Ollama
# listens on 0.0.0.0 (OLLAMA_HOST=0.0.0.0 in Ollama's own env) to accept it.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Dual Qdrant: local mode queries the local instance, hetzner mode the remote.
QDRANT_HOST_LOCAL=qdrant
QDRANT_PORT_LOCAL=6333
QDRANT_HOST_HETZNER=46.62.202.18
QDRANT_PORT_HETZNER=6333
EMBED_MODEL=nomic-ai/nomic-embed-text-v1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=your_bcrypt_hash_here
WATCH_DIR=/app/watch
CHUNK_SIZE=500
CHUNK_OVERLAP=50
