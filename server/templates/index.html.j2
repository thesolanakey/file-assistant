<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>file-assistant</title>
<style>{% raw %}
  :root {
    --bg:        #0a0d11;
    --panel:     #0e1318;
    --panel-2:   #11171d;
    --border:    #1d262f;
    --border-2:  #283441;
    --text:      #c9d4df;
    --muted:     #5d6b7a;
    --green:     #3fb950;
    --blue:      #58a6ff;
    --amber:     #d29922;
    --red:       #f85149;
    --mono: "JetBrains Mono","Fira Code","SFMono-Regular",ui-monospace,Menlo,Consolas,monospace;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; margin: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font: 13px/1.5 var(--mono);
    display: grid;
    grid-template-rows: 40px 1fr 64px;
    grid-template-columns: 1fr;
    overflow: hidden;
    letter-spacing: .2px;
  }
  ::selection { background: rgba(63,185,80,.3); }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }

  /* ---------- TOPBAR ---------- */
  .topbar {
    grid-row: 1; display: flex; align-items: center; gap: 12px;
    padding: 0 14px; background: var(--panel);
    border-bottom: 1px solid var(--border);
  }
  .brand { display: flex; align-items: center; gap: 9px; }
  .title { font-weight: 600; color: var(--text); }
  .status-text { color: var(--muted); margin-left: 6px; }
  .status-text b { color: var(--green); font-weight: 600; }
  .topbar .spacer { flex: 1; }
  .badges { display: flex; gap: 7px; }
  .badge {
    border: 1px solid var(--border-2); border-radius: 4px;
    padding: 2px 8px; color: var(--muted); font-size: 11px; white-space: nowrap;
  }
  .badge b { color: var(--text); font-weight: 600; }
  .badge.ok b   { color: var(--green); }
  .badge.down b { color: var(--red); }

  /* animated icon: pulsing core + 3 orbiting dots */
  .icon { position: relative; width: 22px; height: 22px; flex: 0 0 22px; }
  .icon .core {
    position: absolute; inset: 0; margin: auto; width: 6px; height: 6px;
    border-radius: 50%; background: var(--green);
    box-shadow: 0 0 6px var(--green); animation: pulse 1.6s ease-in-out infinite;
  }
  .icon .orbit { position: absolute; inset: 0; animation: spin 3s linear infinite; }
  .icon .orbit .d {
    position: absolute; top: 50%; left: 50%; width: 4px; height: 4px;
    margin: -2px 0 0 -2px; border-radius: 50%; background: var(--green);
    opacity: .85;
  }
  .icon .orbit .d:nth-child(1) { transform: rotate(0deg)   translateX(9px); }
  .icon .orbit .d:nth-child(2) { transform: rotate(120deg) translateX(9px); }
  .icon .orbit .d:nth-child(3) { transform: rotate(240deg) translateX(9px); }
  @keyframes spin  { to { transform: rotate(360deg); } }
  @keyframes pulse { 0%,100% { transform: scale(.6); opacity: .55; } 50% { transform: scale(1.35); opacity: 1; } }

  /* ---------- MIDDLE GRID ---------- */
  .middle {
    grid-row: 2; display: grid;
    grid-template-columns: 200px 1fr 210px;
    min-height: 0;
  }
  .panel { background: var(--panel); min-height: 0; overflow-y: auto; }
  .left  { border-right: 1px solid var(--border); display: flex; flex-direction: column; }
  .right { border-left: 1px solid var(--border); }
  .centre { background: var(--bg); min-height: 0; overflow-y: auto; }

  .section { padding: 12px 12px 6px; }
  .section h3 {
    margin: 0 0 8px; font-size: 10px; letter-spacing: 1px; text-transform: uppercase;
    color: var(--muted); font-weight: 600;
  }
  .row { display: flex; align-items: center; justify-content: space-between; margin: 6px 0; gap: 8px; }
  .row .k { color: var(--muted); }
  .row .v { color: var(--text); }

  /* dropdown */
  .dd { position: relative; width: 100%; }
  .dd-btn {
    width: 100%; text-align: left; background: var(--panel-2); color: var(--text);
    border: 1px solid var(--border-2); border-radius: 4px; padding: 6px 8px;
    font: inherit; cursor: pointer; display: flex; align-items: center; gap: 7px;
  }
  .dd-btn:hover { border-color: var(--green); }
  .dd-btn .caret { margin-left: auto; color: var(--muted); }
  .dd-menu {
    position: absolute; z-index: 50; left: 0; right: 0; top: calc(100% + 3px);
    background: var(--panel-2); border: 1px solid var(--border-2); border-radius: 4px;
    overflow: hidden; display: none; box-shadow: 0 6px 18px rgba(0,0,0,.5);
  }
  .dd.open .dd-menu { display: block; }
  .dd.up .dd-menu { top: auto; bottom: calc(100% + 3px); }
  .dd-opt { padding: 6px 8px; cursor: pointer; display: flex; align-items: center; gap: 7px; }
  .dd-opt:hover { background: rgba(88,166,255,.12); }
  .dd-opt.sel { color: var(--green); }

  .dot { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 8px; }
  .dot.local { background: var(--green); box-shadow: 0 0 5px var(--green); }
  .dot.hetzner { background: var(--blue); box-shadow: 0 0 5px var(--blue); }

  /* toggle */
  .toggle { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
  .switch { width: 32px; height: 18px; border-radius: 10px; background: var(--border-2); position: relative; transition: .15s; }
  .switch::after { content: ""; position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; border-radius: 50%; background: var(--muted); transition: .15s; }
  .toggle.on .switch { background: rgba(63,185,80,.4); }
  .toggle.on .switch::after { left: 16px; background: var(--green); }

  /* viz placeholder */
  .left .viz-wrap { margin-top: auto; padding: 12px; }
  .viz {
    position: relative; height: 90px; border: 1px dashed var(--border-2); border-radius: 5px;
    overflow: hidden; display: flex; align-items: flex-end; justify-content: center; gap: 4px; padding: 10px;
  }
  .viz::before {
    content: ""; position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, rgba(63,185,80,.05) 0, rgba(63,185,80,.05) 1px, transparent 1px, transparent 4px);
    animation: scan 6s linear infinite;
  }
  @keyframes scan { from { background-position: 0 0; } to { background-position: 0 60px; } }
  .viz .bar { width: 7px; background: var(--green); opacity: .5; border-radius: 2px 2px 0 0; animation: bars 1.4s ease-in-out infinite; }
  .viz .bar:nth-child(2){ animation-delay: .15s; } .viz .bar:nth-child(3){ animation-delay: .3s; }
  .viz .bar:nth-child(4){ animation-delay: .45s; } .viz .bar:nth-child(5){ animation-delay: .6s; }
  @keyframes bars { 0%,100% { height: 18%; } 50% { height: 80%; } }
  .viz .label { position: absolute; top: 5px; left: 7px; color: var(--muted); font-size: 10px; }

  /* ---------- CHAT ---------- */
  .chat { max-width: 760px; margin: 0 auto; padding: 18px 18px 28px; display: flex; flex-direction: column; gap: 14px; }
  .msg { display: flex; flex-direction: column; max-width: 86%; }
  .msg.user { align-self: flex-end; align-items: flex-end; }
  .msg.ai { align-self: flex-start; align-items: flex-start; }
  .bubble { padding: 9px 12px; border-radius: 8px; white-space: pre-wrap; word-wrap: break-word; }
  .msg.user .bubble { background: #16324f; border: 1px solid #1f4368; }
  .msg.ai .bubble { background: var(--panel-2); border: 1px solid var(--border); }
  .meta { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-top: 5px; font-size: 11px; color: var(--muted); }
  .tag { border: 1px solid var(--border-2); border-radius: 3px; padding: 0 6px; color: var(--text); font-size: 10px; }
  .tag.mode-local { border-color: rgba(63,185,80,.5); color: var(--green); }
  .tag.mode-hetzner { border-color: rgba(88,166,255,.5); color: var(--blue); }
  .tag.src { color: var(--amber); border-color: rgba(210,153,34,.4); }
  .be { color: var(--muted); }
  .be .b-ollama { color: var(--green); } .be .b-claude { color: var(--blue); } .be .b-retrieval { color: var(--muted); }
  .empty { color: var(--muted); text-align: center; margin-top: 40px; }

  /* ---------- RIGHT PANEL ---------- */
  .drop {
    margin: 4px 0; border: 1px dashed var(--border-2); border-radius: 5px;
    padding: 16px 10px; text-align: center; color: var(--muted); cursor: pointer; transition: .15s;
  }
  .drop:hover, .drop.over { border-color: var(--green); color: var(--text); background: rgba(63,185,80,.05); }
  .files { display: flex; flex-direction: column; gap: 8px; }
  .file { border: 1px solid var(--border); border-radius: 4px; padding: 7px 8px; background: var(--panel-2); }
  .file .fn { color: var(--text); font-size: 11px; word-break: break-all; margin-bottom: 5px; }
  .file .fn .ck { color: var(--muted); }
  .upload-status { font-size: 11px; color: var(--muted); min-height: 14px; margin-top: 4px; }

  /* ---------- INPUT BAR ---------- */
  .inputbar { grid-row: 3; display: flex; align-items: center; gap: 10px; padding: 0 14px; background: var(--panel); border-top: 1px solid var(--border); }
  .inputbar .dd { width: 150px; flex: 0 0 150px; }
  .inputbar input[type=text] {
    flex: 1; background: var(--panel-2); color: var(--text); border: 1px solid var(--border-2);
    border-radius: 5px; padding: 10px 12px; font: inherit;
  }
  .inputbar input[type=text]:focus { outline: none; border-color: var(--green); }
  .send { background: #15351f; color: var(--green); border: 1px solid #1f5630; border-radius: 5px; padding: 0 18px; height: 38px; font: inherit; font-weight: 600; cursor: pointer; }
  .send:hover { background: #1a4226; }
  .send:disabled { opacity: .5; cursor: default; }
{% endraw %}</style>
</head>
<body
  data-mode="{{ mode }}"
  data-backend="{{ backend }}"
  data-model="{{ model }}"
  data-fallback="{{ fallback|lower }}">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="brand">
      <div class="icon"><span class="core"></span><span class="orbit"><span class="d"></span><span class="d"></span><span class="d"></span></span></div>
      <span class="title">file-assistant</span>
      <span class="status-text" id="statusText"></span>
    </div>
    <div class="spacer"></div>
    <div class="badges">
      <span class="badge" id="bgBackend">backend: <b>—</b></span>
      <span class="badge" id="bgModel">model: <b>—</b></span>
      <span class="badge" id="bgQdrant">qdrant: <b>—</b></span>
    </div>
  </div>

  <!-- MIDDLE -->
  <div class="middle">

    <!-- LEFT -->
    <div class="panel left">
      <div class="section">
        <h3>backend</h3>
        <div class="dd" id="ddBackend" data-kind="backend">
          <button class="dd-btn"><span class="cur">ollama</span><span class="caret">▾</span></button>
          <div class="dd-menu">
            <div class="dd-opt" data-val="ollama">ollama</div>
            <div class="dd-opt" data-val="claude">claude api</div>
          </div>
        </div>
        <div class="row" style="margin-top:10px">
          <span class="k">auto fallback</span>
          <span class="toggle on" id="tgFallback"><span class="switch"></span></span>
        </div>
      </div>

      <div class="section">
        <h3>model</h3>
        <div class="dd" id="ddModel" data-kind="model">
          <button class="dd-btn"><span class="cur">llama3.2</span><span class="caret">▾</span></button>
          <div class="dd-menu">
            <div class="dd-opt" data-val="llama3.2">llama3.2</div>
            <div class="dd-opt" data-val="qwen2.5:7b">qwen2.5:7b</div>
          </div>
        </div>
      </div>

      <div class="section">
        <h3>status</h3>
        <div class="row"><span class="k">t/s</span><span class="v" id="stTps">—</span></div>
        <div class="row"><span class="k">qdrant docs</span><span class="v" id="stDocs">—</span></div>
        <div class="row"><span class="k">memory msgs</span><span class="v" id="stMsgs">—</span></div>
        <div class="row"><span class="k">ram</span><span class="v" id="stRam">—</span></div>
      </div>

      <div class="viz-wrap">
        <div class="viz">
          <span class="label">// viz</span>
          <span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
        </div>
      </div>
    </div>

    <!-- CENTRE -->
    <div class="centre" id="centre">
      <div class="chat" id="chat">
        <div class="empty" id="empty">// conversation history</div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="panel right">
      <div class="section">
        <h3>ingest</h3>
        <div class="drop" id="drop">drop a file<br/>or click to select</div>
        <input type="file" id="fileInput" style="display:none" />
        <div class="row" style="margin-top:8px">
          <span class="k">store to</span>
          <div class="dd" id="ddStore" data-kind="store" style="width:96px">
            <button class="dd-btn"><span class="dot local"></span><span class="cur">local</span><span class="caret">▾</span></button>
            <div class="dd-menu">
              <div class="dd-opt" data-val="local"><span class="dot local"></span>local</div>
              <div class="dd-opt" data-val="hetzner"><span class="dot hetzner"></span>hetzner</div>
            </div>
          </div>
        </div>
        <div class="upload-status" id="uploadStatus"></div>
      </div>

      <div class="section">
        <h3>indexed files</h3>
        <div class="files" id="files"></div>
      </div>
    </div>
  </div>

  <!-- INPUT BAR -->
  <div class="inputbar">
    <div class="dd up" id="ddMode" data-kind="mode">
      <button class="dd-btn"><span class="dot local"></span><span class="cur">local</span><span class="caret">▾</span></button>
      <div class="dd-menu">
        <div class="dd-opt" data-val="local"><span class="dot local"></span>local</div>
        <div class="dd-opt" data-val="hetzner"><span class="dot hetzner"></span>hetzner</div>
      </div>
    </div>
    <input type="text" id="chatInput" placeholder="ask about your files…  (enter to send)" autocomplete="off" />
    <button class="send" id="sendBtn">send</button>
  </div>

<script>{% raw %}
(() => {
  "use strict";
  const $ = (id) => document.getElementById(id);
  const ds = document.body.dataset;
  const state = {
    mode: ds.mode || "local",
    backend: ds.backend || "ollama",
    model: ds.model || "llama3.2",
    fallback: ds.fallback === "true",
    store: "local",
    busy: false,
  };

  const el = (tag, cls, text) => {
    const e = document.createElement(tag);
    if (cls) e.className = cls;
    if (text != null) e.textContent = text;
    return e;
  };
  async function api(method, url, body) {
    const opt = { method, headers: {} };
    if (body !== undefined) { opt.headers["Content-Type"] = "application/json"; opt.body = JSON.stringify(body); }
    const r = await fetch(url, opt);
    const data = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(data.detail || ("HTTP " + r.status));
    return data;
  }

  // ---------- topbar reactivity ----------
  function paintTopbar(h) {
    state.mode = (h && h.mode) || state.mode;
    state.backend = (h && h.backend) || state.backend;
    state.model = (h && h.model) || state.model;
    const beLabel = state.backend === "claude" ? "claude" : state.backend;
    $("statusText").innerHTML = "// <b>" + state.mode + "</b> · " + beLabel;
    $("bgBackend").innerHTML = "backend: <b>" + beLabel + "</b>";
    $("bgModel").innerHTML = "model: <b>" + state.model + "</b>";
    if (h) {
      const q = $("bgQdrant");
      q.innerHTML = "qdrant: <b>" + (h.qdrant || "—") + "</b>";
      q.className = "badge " + (h.qdrant === "ok" ? "ok" : h.qdrant === "down" ? "down" : "");
    }
  }

  // ---------- live status poll ----------
  async function poll() {
    try {
      const h = await api("GET", "/health");
      paintTopbar(h);
      $("stTps").textContent  = h.tps != null ? h.tps + " t/s" : "—";
      $("stDocs").textContent = h.doc_count != null ? h.doc_count : "—";
      $("stMsgs").textContent = h.msg_count != null ? h.msg_count : "—";
      $("stRam").textContent  = h.ram != null ? h.ram + "%" : "—";
    } catch (e) { /* keep last values */ }
  }

  // ---------- dropdowns ----------
  function closeAllDD(except) {
    document.querySelectorAll(".dd.open").forEach(d => { if (d !== except) d.classList.remove("open"); });
  }
  function setDDLabel(dd, val, withDot) {
    const cur = dd.querySelector(".dd-btn .cur");
    cur.textContent = val === "claude" ? "claude api" : val;
    if (withDot) {
      let dot = dd.querySelector(".dd-btn .dot");
      if (dot) dot.className = "dot " + val;
    }
    dd.querySelectorAll(".dd-opt").forEach(o => o.classList.toggle("sel", o.dataset.val === val));
  }
  function initDD(id, onSelect, withDot) {
    const dd = $(id);
    dd.querySelector(".dd-btn").addEventListener("click", (e) => {
      e.stopPropagation();
      const open = dd.classList.contains("open");
      closeAllDD();
      dd.classList.toggle("open", !open);
    });
    dd.querySelectorAll(".dd-opt").forEach(opt => {
      opt.addEventListener("click", (e) => {
        e.stopPropagation();
        dd.classList.remove("open");
        const val = opt.dataset.val;
        setDDLabel(dd, val, withDot);
        onSelect(val);
      });
    });
    return dd;
  }
  document.addEventListener("click", () => closeAllDD());

  initDD("ddBackend", async (val) => {
    try { await api("POST", "/config", { backend: val }); state.backend = val; paintTopbar(); }
    catch (e) { console.warn(e); }
  });
  initDD("ddModel", async (val) => {
    try { await api("POST", "/config", { model: val }); state.model = val; paintTopbar(); }
    catch (e) { console.warn(e); }
  });
  initDD("ddStore", (val) => { state.store = val; }, true);
  initDD("ddMode", async (val) => {
    try { await api("POST", "/mode", { mode: val }); state.mode = val; paintTopbar(); }
    catch (e) { console.warn(e); }
  }, true);

  // fallback toggle
  $("tgFallback").addEventListener("click", async () => {
    const tg = $("tgFallback");
    const next = !tg.classList.contains("on");
    tg.classList.toggle("on", next);
    state.fallback = next;
    try { await api("POST", "/config", { fallback: next }); } catch (e) { console.warn(e); }
  });

  // ---------- chat ----------
  function scrollDown() { $("centre").scrollTop = 1e9; }
  function addUser(text) {
    const e = $("empty"); if (e) e.remove();
    const m = el("div", "msg user"); m.appendChild(el("div", "bubble", text));
    $("chat").appendChild(m); scrollDown();
  }
  function aiMeta(d) {
    const meta = el("div", "meta");
    const m = d.active_mode || d.mode;
    if (m === "local" || m === "hetzner") meta.appendChild(el("span", "tag mode-" + m, m));
    (d.sources || []).forEach(s => meta.appendChild(el("span", "tag src", s)));
    if (d.backend) {
      const be = el("span", "be");
      const speed = d.tps != null ? " · " + d.tps + " t/s" : "";
      be.innerHTML = '<span class="b-' + d.backend + '">' + d.backend + "</span>" + speed;
      meta.appendChild(be);
    }
    return meta;
  }
  function addAiPlaceholder() {
    const m = el("div", "msg ai");
    const b = el("div", "bubble"); b.textContent = "…"; b.style.color = "var(--muted)";
    m.appendChild(b); $("chat").appendChild(m); scrollDown();
    return m;
  }
  function renderAi(m, d) {
    m.innerHTML = "";
    const b = el("div", "bubble");
    if (d.answer != null) {
      b.textContent = d.answer;
    } else if (d.chunks && d.chunks.length) {
      b.textContent = d.chunks.map(c => "› " + (c.filename || "?") + "\n" + (c.text || "").slice(0, 200)).join("\n\n");
    } else {
      b.textContent = "(no result)";
    }
    m.appendChild(b);
    m.appendChild(aiMeta(d));
    scrollDown();
  }

  async function send() {
    const inp = $("chatInput");
    const text = inp.value.trim();
    if (!text || state.busy) return;
    state.busy = true; $("sendBtn").disabled = true;
    addUser(text); inp.value = "";
    const ph = addAiPlaceholder();
    try {
      const d = await api("POST", "/query", { question: text });
      renderAi(ph, d);
    } catch (e) {
      ph.innerHTML = ""; const b = el("div", "bubble", "error: " + e.message); b.style.color = "var(--red)"; ph.appendChild(b);
    } finally {
      state.busy = false; $("sendBtn").disabled = false; inp.focus();
      poll();
    }
  }
  $("sendBtn").addEventListener("click", send);
  $("chatInput").addEventListener("keydown", (e) => { if (e.key === "Enter") { e.preventDefault(); send(); } });

  // ---------- history ----------
  async function loadHistory() {
    try {
      const d = await api("GET", "/history");
      const msgs = d.messages || [];
      if (!msgs.length) return;
      const e = $("empty"); if (e) e.remove();
      msgs.forEach(msg => {
        if (msg.role === "user") {
          const m = el("div", "msg user"); m.appendChild(el("div", "bubble", msg.content));
          $("chat").appendChild(m);
        } else {
          const m = el("div", "msg ai"); m.appendChild(el("div", "bubble", msg.content));
          m.appendChild(aiMeta({ active_mode: msg.mode }));
          $("chat").appendChild(m);
        }
      });
      scrollDown();
    } catch (e) { /* ignore */ }
  }

  // ---------- files ----------
  const TAGS = ["remember", "storage", "project"];
  async function loadFiles() {
    try {
      const d = await api("GET", "/files");
      const wrap = $("files"); wrap.innerHTML = "";
      if (!d.files || !d.files.length) { wrap.appendChild(el("div", "k", "// none")); return; }
      d.files.forEach(f => {
        const card = el("div", "file");
        const fn = el("div", "fn"); fn.innerHTML = f.filename + ' <span class="ck">(' + (f.chunks || 0) + ")</span>";
        card.appendChild(fn);
        const dd = buildTagDD(f.filename, f.tag || "");
        card.appendChild(dd);
        wrap.appendChild(card);
      });
    } catch (e) { /* ignore */ }
  }
  function buildTagDD(filename, current) {
    const dd = el("div", "dd");
    const btn = el("button", "dd-btn");
    btn.innerHTML = '<span class="cur">' + (current || "tag…") + '</span><span class="caret">▾</span>';
    const menu = el("div", "dd-menu");
    TAGS.forEach(t => {
      const o = el("div", "dd-opt" + (t === current ? " sel" : ""), t);
      o.addEventListener("click", async (e) => {
        e.stopPropagation(); dd.classList.remove("open");
        btn.querySelector(".cur").textContent = t;
        try { await api("POST", "/files/" + encodeURIComponent(filename) + "/tag", { tag: t }); }
        catch (err) { console.warn(err); }
      });
      menu.appendChild(o);
    });
    btn.addEventListener("click", (e) => { e.stopPropagation(); const open = dd.classList.contains("open"); closeAllDD(); dd.classList.toggle("open", !open); });
    dd.appendChild(btn); dd.appendChild(menu);
    return dd;
  }

  // ---------- upload ----------
  async function uploadFile(file) {
    if (!file) return;
    const st = $("uploadStatus"); st.textContent = "uploading " + file.name + " → " + state.store + " …";
    const fd = new FormData();
    fd.append("file", file);
    fd.append("destination", state.store);     // store-to passed with the ingest call
    try {
      const r = await fetch("/upload", { method: "POST", body: fd });
      const d = await r.json().catch(() => ({}));
      if (!r.ok) throw new Error(d.detail || ("HTTP " + r.status));
      st.textContent = (d.status || "ingested") + ": " + (d.filename || file.name);
      loadFiles(); poll();
    } catch (e) { st.textContent = "error: " + e.message; }
  }
  const drop = $("drop"), fileInput = $("fileInput");
  drop.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", () => { if (fileInput.files[0]) uploadFile(fileInput.files[0]); fileInput.value = ""; });
  ["dragenter", "dragover"].forEach(ev => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add("over"); }));
  ["dragleave", "drop"].forEach(ev => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove("over"); }));
  drop.addEventListener("drop", (e) => { const f = e.dataTransfer.files[0]; if (f) uploadFile(f); });

  // ---------- init ----------
  function applyInitial() {
    setDDLabel($("ddBackend"), state.backend, false);
    setDDLabel($("ddModel"), state.model, false);
    setDDLabel($("ddMode"), state.mode, true);
    setDDLabel($("ddStore"), state.store, true);
    $("tgFallback").classList.toggle("on", state.fallback);
    paintTopbar();
  }
  applyInitial();
  loadHistory();
  loadFiles();
  poll();
  setInterval(poll, 5000);
  $("chatInput").focus();
})();
{% endraw %}</script>
</body>
