<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>file-assistant</title>
<style>{% raw %}
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    background: #0a0e1a;
    color: #e2e8f0;
    font-family: 'JetBrains Mono', 'Fira Mono', ui-monospace, 'Cascadia Code', Consolas, monospace;
    height: 100vh;
    overflow: hidden;
    display: flex;
  }

  /* scrollbars */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #1e2a3a; border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: #2e4a60; }

  /* ───────── SIDEBAR ───────── */
  .sidebar {
    width: 220px;
    flex: 0 0 auto;
    background: #0d1220;
    border-right: 0.5px solid #1e2a3a;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: width 0.2s ease;
  }
  .sidebar.collapsed { width: 48px; }

  .sb-top {
    height: 52px;
    flex: 0 0 auto;
    padding: 12px 10px;
    border-bottom: 0.5px solid #1e2a3a;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .sb-title {
    font-size: 11px;
    color: #4a6580;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
    overflow: hidden;
    transition: opacity 0.15s ease;
  }
  .sidebar.collapsed .sb-title { opacity: 0; }
  .collapse-btn {
    width: 26px; height: 26px;
    flex: 0 0 auto;
    border: 0.5px solid #1e2a3a;
    border-radius: 5px;
    background: transparent;
    color: #4a6580;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    display: flex; align-items: center; justify-content: center;
  }
  .collapse-btn:hover { color: #1D9E75; background: #111827; }

  /* full (expanded) content — hidden when collapsed */
  .sb-full { display: flex; flex-direction: column; flex: 1; min-height: 0; }
  .sidebar.collapsed .sb-full { display: none; }

  .backend-toggle { padding: 10px 10px 0; }
  .pill {
    background: #111827;
    border-radius: 8px;
    padding: 3px;
    display: flex;
    gap: 2px;
  }
  .pill-btn {
    flex: 1;
    border: none;
    background: transparent;
    color: #4a6580;
    padding: 6px 8px;
    border-radius: 6px;
    font-family: inherit;
    font-size: 11px;
    cursor: pointer;
  }
  .pill-btn.active { background: #1D9E75; color: #04342C; font-weight: 500; }

  .sb-label {
    font-size: 10px;
    color: #2e4a60;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 14px 14px 6px;
  }
  .new-chat {
    margin: 0 10px 8px;
    padding: 7px 10px;
    border: 0.5px solid #1e2a3a;
    border-radius: 6px;
    background: transparent;
    color: #4a8a6a;
    font-family: inherit;
    font-size: 12px;
    text-align: left;
    cursor: pointer;
  }
  .new-chat:hover { border-color: rgba(29,158,117,0.4); color: #1D9E75; }

  .convo-list { flex: 1; overflow-y: auto; padding: 0 10px 10px; }
  .convo {
    padding: 8px 10px;
    border-radius: 6px;
    margin-bottom: 2px;
    cursor: pointer;
    border: 0.5px solid transparent;
  }
  .convo:hover { background: #111827; }
  .convo.active {
    background: #0f1e2e;
    border: 0.5px solid rgba(29,158,117,0.2);
  }
  .convo-title {
    font-size: 12px;
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .convo.active .convo-title { color: #1D9E75; }
  .convo-date { font-size: 10px; color: #2e4a60; margin-top: 2px; }

  /* collapsed icon rail */
  .sb-rail { display: none; }
  .sidebar.collapsed .sb-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
  }
  .rail-icon {
    position: relative;
    width: 28px; height: 28px;
    border-radius: 6px;
    background: transparent;
    border: none;
    color: #4a6580;
    cursor: pointer;
    font-size: 15px;
    display: flex; align-items: center; justify-content: center;
  }
  .rail-icon:hover { background: #111827; color: #1D9E75; }
  .rail-dot {
    position: absolute;
    right: 3px; bottom: 3px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #1D9E75;
  }

  /* ───────── MAIN ───────── */
  .main { display: flex; flex-direction: column; flex: 1; overflow: hidden; min-width: 0; }

  .chat {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .msg { display: flex; flex-direction: column; max-width: 80%; }
  .msg.ai { align-self: flex-start; }
  .msg.user { align-self: flex-end; align-items: flex-end; }

  .msg-label {
    font-size: 10px;
    color: #1D9E75;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }
  .bubble {
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .msg.ai .bubble { background: #111827; border: 0.5px solid #1e2a3a; color: #cbd5e1; }
  .msg.user .bubble { background: #0f2a1e; border: 0.5px solid rgba(29,158,117,0.2); color: #a7f3d0; }
  .msg-time { font-size: 10px; color: #2e4a60; margin-top: 4px; }

  .typing .bubble .dot { animation: blink 1.2s infinite; }
  .typing .bubble .dot:nth-child(2) { animation-delay: 0.2s; }
  .typing .bubble .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }

  /* ───────── INPUT BAR ───────── */
  .inputbar {
    flex: 0 0 auto;
    background: #0d1220;
    border-top: 0.5px solid #1e2a3a;
    padding: 12px 16px 14px;
  }
  .input-box {
    background: #111827;
    border: 0.5px solid #1e2a3a;
    border-radius: 10px;
  }
  .input-box:focus-within { border-color: rgba(29,158,117,0.4); }

  .file-chip-row {
    display: none;
    padding: 6px 12px;
    border-bottom: 0.5px solid #1e2a3a;
  }
  .file-chip-row.show { display: flex; }
  .file-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #0f1e2e;
    border: 0.5px solid #1e2a3a;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 11px;
    color: #94a3b8;
  }
  .chip-x {
    border: none; background: transparent; color: #94a3b8;
    cursor: pointer; font-family: inherit; font-size: 11px; padding: 0;
  }
  .chip-x:hover { color: #f87171; }

  .input-row { padding: 10px 12px; display: flex; align-items: flex-end; gap: 10px; }
  .icon-btn {
    flex: 0 0 auto;
    width: 28px; height: 28px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
    font-size: 15px;
    display: flex; align-items: center; justify-content: center;
  }
  .attach-btn { color: #4a6580; }
  .attach-btn:hover { background: #1e2a3a; }
  .send-btn { background: #1D9E75; color: #04342C; font-size: 13px; }
  .send-btn:hover { background: #22b888; }

  textarea#input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    font-family: inherit;
    font-size: 13px;
    color: #e2e8f0;
    line-height: 1.5;
    max-height: 100px;
    overflow-y: auto;
  }
  textarea#input::placeholder { color: #2e4a60; }

  .slash-bar {
    padding: 0 12px 10px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .slash-btn {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 4px;
    background: #0a0e1a;
    border: 0.5px solid #1e2a3a;
    color: #4a8a6a;
    font-family: inherit;
    cursor: pointer;
  }
  .slash-btn:hover { border-color: rgba(29,158,117,0.4); color: #1D9E75; background: #0f2a1e; }
{% endraw %}</style>
</head>
<body
  data-mode="{{ mode }}"
  data-backend="{{ backend }}"
  data-model="{{ model }}"
  data-fallback="{{ fallback|lower }}">

  <!-- ───────── SIDEBAR ───────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-top">
      <span class="sb-title">file-assistant</span>
      <button class="collapse-btn" id="collapseBtn" title="toggle sidebar">&#9776;</button>
    </div>

    <div class="sb-full">
      <div class="backend-toggle">
        <div class="pill" id="pill">
          <button class="pill-btn" data-val="assistant">assistant</button>
          <button class="pill-btn" data-val="friend">friend</button>
        </div>
      </div>

      <div class="sb-label">conversations</div>
      <button class="new-chat" id="newChat">+ new chat</button>
      <div class="convo-list" id="convoList"></div>
    </div>

    <div class="sb-rail">
      <button class="rail-icon" id="railChat" title="chat">&#128172;<span class="rail-dot"></span></button>
      <button class="rail-icon" id="railNew" title="new chat">+</button>
      <button class="rail-icon" id="railServer" title="backend">&#11041;</button>
    </div>
  </aside>

  <!-- ───────── MAIN ───────── -->
  <main class="main">
    <div class="chat" id="chat"></div>

    <div class="inputbar">
      <div class="input-box">
        <div class="file-chip-row" id="fileChipRow">
          <span class="file-chip"><span id="fileName"></span><button class="chip-x" id="chipX" title="remove">&#10005;</button></span>
        </div>
        <div class="input-row">
          <button class="icon-btn attach-btn" id="attachBtn" title="attach file">&#128206;</button>
          <input type="file" id="fileInput" style="display:none" />
          <textarea id="input" rows="1" placeholder="ask anything, or type / for commands..."></textarea>
          <button class="icon-btn send-btn" id="sendBtn" title="send">&#10148;</button>
        </div>
      </div>
      <div class="slash-bar" id="slashBar">
        <button class="slash-btn" data-cmd="/search">/search</button>
        <button class="slash-btn" data-cmd="/ingest">/ingest</button>
        <button class="slash-btn" data-cmd="/process">/process</button>
        <button class="slash-btn" data-cmd="/dataset">/dataset</button>
        <button class="slash-btn" data-cmd="/tag">/tag</button>
        <button class="slash-btn" data-cmd="/files">/files</button>
        <button class="slash-btn" data-cmd="/clear">/clear</button>
      </div>
    </div>
  </main>

<script>{% raw %}
(() => {
  "use strict";
  const $ = (id) => document.getElementById(id);
  const ds = document.body.dataset;
  const state = { backend: ds.backend || "ollama", mode: ds.mode || "assistant", attached: null, busy: false };

  const sidebar   = $("sidebar");
  const chat      = $("chat");
  const input     = $("input");
  const sendBtn   = $("sendBtn");
  const attachBtn = $("attachBtn");
  const fileInput = $("fileInput");
  const chipRow   = $("fileChipRow");
  const fileName  = $("fileName");
  const convoList = $("convoList");

  // ── helpers ──
  function fmtTime(iso) {
    try { return new Date(iso || Date.now()).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }); }
    catch (e) { return ""; }
  }
  function fmtDate(iso) {
    try { return new Date(iso || Date.now()).toLocaleDateString([], { month: "short", day: "numeric" }); }
    catch (e) { return ""; }
  }
  function scrollBottom() { chat.scrollTop = chat.scrollHeight; }

  async function api(method, url, body) {
    const opt = { method, headers: {} };
    if (body !== undefined) { opt.headers["Content-Type"] = "application/json"; opt.body = JSON.stringify(body); }
    const r = await fetch(url, opt);
    const d = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(d.detail || ("HTTP " + r.status));
    return d;
  }

  // ── messages ──
  function addMessage(role, text, ts) {
    const wrap = document.createElement("div");
    wrap.className = "msg " + (role === "user" ? "user" : "ai");
    if (role !== "user") {
      const lbl = document.createElement("div");
      lbl.className = "msg-label";
      lbl.textContent = "// file-assistant";
      wrap.appendChild(lbl);
    }
    const bub = document.createElement("div");
    bub.className = "bubble";
    bub.textContent = text;
    wrap.appendChild(bub);
    const t = document.createElement("div");
    t.className = "msg-time";
    t.textContent = fmtTime(ts);
    wrap.appendChild(t);
    chat.appendChild(wrap);
    scrollBottom();
    return wrap;
  }

  function showTyping() {
    const wrap = document.createElement("div");
    wrap.className = "msg ai typing";
    wrap.id = "typingIndicator";
    const lbl = document.createElement("div");
    lbl.className = "msg-label";
    lbl.textContent = "// file-assistant";
    const bub = document.createElement("div");
    bub.className = "bubble";
    bub.innerHTML = '// thinking<span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>';
    wrap.appendChild(lbl);
    wrap.appendChild(bub);
    chat.appendChild(wrap);
    scrollBottom();
  }
  function removeTyping() {
    const t = $("typingIndicator");
    if (t) t.remove();
  }

  // ── history ──
  function renderConvoList(msgs) {
    convoList.innerHTML = "";
    if (!msgs.length) return;
    const firstUser = msgs.find((m) => m.role === "user");
    const item = document.createElement("div");
    item.className = "convo active";
    const tt = document.createElement("div");
    tt.className = "convo-title";
    tt.textContent = firstUser ? firstUser.content : "conversation";
    const dd = document.createElement("div");
    dd.className = "convo-date";
    dd.textContent = fmtDate(msgs[0].created_at);
    item.appendChild(tt);
    item.appendChild(dd);
    item.addEventListener("click", loadHistory);
    convoList.appendChild(item);
  }

  async function loadHistory() {
    let d;
    try { d = await api("GET", "/history"); } catch (e) { return; }
    const msgs = d.messages || [];
    chat.innerHTML = "";
    msgs.forEach((m) => addMessage(m.role === "user" ? "user" : "ai", m.content, m.created_at));
    renderConvoList(msgs);
    scrollBottom();
  }

  // ── profile toggle (assistant / friend; posts /mode) ──
  function setProfileActive(val) {
    document.querySelectorAll(".pill-btn").forEach((b) => b.classList.toggle("active", b.dataset.val === val));
  }
  document.querySelectorAll(".pill-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const val = btn.dataset.val;
      try {
        await api("POST", "/mode", { mode: val });
        state.mode = val;
        setProfileActive(val);
        // History is per profile — reload this profile's conversation.
        await loadHistory();
      } catch (e) { console.warn("profile change failed:", e.message); }
    });
  });

  // ── file attach ──
  function clearFile() {
    state.attached = null;
    fileInput.value = "";
    chipRow.classList.remove("show");
  }
  attachBtn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", () => {
    const f = fileInput.files[0];
    if (!f) return;
    state.attached = f;
    fileName.textContent = f.name;
    chipRow.classList.add("show");
  });
  $("chipX").addEventListener("click", clearFile);

  // ── send ──
  async function send() {
    const text = input.value.trim();
    if (!text || state.busy) return;
    state.busy = true; sendBtn.disabled = true;

    addMessage("user", text);
    input.value = ""; input.style.height = "auto";
    const file = state.attached;
    clearFile();
    showTyping();

    try {
      // slash command: /dataset builds a knowledge dataset from this conversation
      if (text === "/dataset" || text.startsWith("/dataset ")) {
        const dd = await api("POST", "/dataset/build");
        removeTyping();
        let msg = dd.note
          ? "// " + dd.note
          : "// extracted " + dd.extracted + " items and ingested " + dd.ingested + " into knowledge base";
        if (dd.items && dd.items.length) msg += "\n" + dd.items.map((t) => "› " + t).join("\n");
        addMessage("ai", msg);
        return;
      }
      let filename = null;
      if (file) {
        const fd = new FormData();
        fd.append("file", file);
        const r = await fetch("/upload", { method: "POST", body: fd });
        const d = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(d.detail || "upload failed");
        filename = d.filename || file.name;
      }
      // Backend's /query reads `question`; `message`/`filename` included per spec.
      const d = await api("POST", "/query", { question: text, message: text, filename });
      removeTyping();
      const ai = d.answer != null
        ? d.answer
        : (d.chunks && d.chunks.length
            ? d.chunks.map((c) => "› " + (c.filename || "?") + "\n" + (c.text || "").slice(0, 200)).join("\n\n")
            : (d.results || "(no response)"));
      addMessage("ai", ai);
    } catch (e) {
      removeTyping();
      addMessage("ai", "// error: " + e.message);
    } finally {
      state.busy = false; sendBtn.disabled = false; input.focus();
    }
  }
  sendBtn.addEventListener("click", send);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); send(); }
  });
  input.addEventListener("input", () => {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 100) + "px";
  });

  // ── slash command buttons (insert text + focus) ──
  document.querySelectorAll(".slash-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      input.value = btn.dataset.cmd + " ";
      input.focus();
      input.dispatchEvent(new Event("input"));
    });
  });

  // ── new chat ──
  async function newChat() {
    try { await fetch("/history", { method: "DELETE" }); } catch (e) { /* fall back to DOM clear below */ }
    chat.innerHTML = "";
    convoList.innerHTML = "";
    clearFile();
    input.value = ""; input.style.height = "auto";
    input.focus();
  }
  $("newChat").addEventListener("click", newChat);

  // ── collapse / rail ──
  $("collapseBtn").addEventListener("click", () => sidebar.classList.toggle("collapsed"));
  $("railChat").addEventListener("click", () => sidebar.classList.remove("collapsed"));
  $("railNew").addEventListener("click", () => { sidebar.classList.remove("collapsed"); newChat(); });
  $("railServer").addEventListener("click", () => sidebar.classList.remove("collapsed"));

  // ── init ──
  document.addEventListener("DOMContentLoaded", () => {
    state.mode = ds.mode === "friend" ? "friend" : "assistant";  // 1. active profile
    setProfileActive(state.mode);                                // 2. reflect profile in toggle
    loadHistory();                                               // 3. populate sidebar + chat
    input.focus();                                               // 4. focus textarea
  });
})();
{% endraw %}</script>
</body>
</html>
